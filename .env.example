# 环境变量示例 — 复制为 .env 并填入实际值
#
# 用 docker compose 一键起时，仅 ANTHROPIC_* 需要宿主填写；其余（REDIS_URL、
# OBJECT_STORAGE_*、RENDER_SERVICE_URL、CDN_BASE_URL 等）由 docker-compose.yml
# 注入，.env 里的同名值不会覆盖 compose（除非 compose 用 ${VAR} 引用）。
# 下面把变量分两类标注：[host] 宿主必填 / [compose] compose 已注入 / [opt] 可选覆盖。

# ===== AI 链路（[host] 必填；国内需走代理）=====
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://your-proxy.example.com
# 对话 / 页级 CRUD 模型。项目上下文默认 step-3.7-flash，保留可配（生产用 claude-sonnet-4-6）
ANTHROPIC_CHAT_MODEL=step-3.7-flash
# 大纲 / 全量重生成模型。项目上下文默认 step-3.7-flash，保留可配（生产用 claude-opus-4-8）
ANTHROPIC_STRUCTURE_MODEL=step-3.7-flash
# [opt] tool_use（生产，Claude）| json（兼容不支持 tool_use 的代理）
AI_OPS_MODE=tool_use

# ===== 渲染调度服务（[compose] 已注入；以下为本地直连起服务时用）=====
RENDER_SERVICE_URL=http://localhost:3100
# [host] 预览 URL 的 base，浏览器需能访问到。compose 默认 localhost:3100 仅本机可用；
# 跨机访问须填服务器实际 IP，如 http://192.168.3.5:3100
PREVIEW_BASE=http://localhost:3100

# ===== 构建队列（[compose] 已注入）=====
REDIS_URL=redis://localhost:6379
# [opt] 构建并发（1-8）；compose 默认 2，生产建议 4-8
BUILD_CONCURRENCY=4
# slidev build 超时（ms），默认 120000
BUILD_TIMEOUT_MS=120000
# [compose] 镜像内已注入：内置组件源目录
COMPONENTS_DIR=
# [compose] 镜像内已注入：slidev 可执行命令（镜像预装时为 slidev）；默认 npx slidev
SLIDEV_BIN=

# ===== 对象存储 / CDN（[compose] 已注入 RustFS；生产按国内选型填写）=====
# S3 兼容：阿里云 OSS / 腾讯云 COS / RustFS 自建
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=us-east-1
# RustFS 自建置 true，OSS/COS 置 false
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
CDN_BASE_URL=
# 无 OSS 时的本地产物回退目录（开发联调用）
LOCAL_STORAGE_ROOT=
