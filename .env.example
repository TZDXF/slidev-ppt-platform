# 环境变量示例 — 复制为 .env 并填入实际值

# AI 链路（国内需走代理）
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://your-proxy.example.com
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
ANTHROPIC_STRUCTURE_MODEL=claude-opus-4-8
# tool_use（生产，Claude）| json（兼容不支持 tool_use 的代理）
AI_OPS_MODE=tool_use

# 渲染调度服务
RENDER_SERVICE_URL=http://localhost:3100

# 构建队列
REDIS_URL=redis://localhost:6379
BUILD_CONCURRENCY=4
# slidev build 超时（ms），默认 120000
BUILD_TIMEOUT_MS=120000
# 内置组件源目录（默认指向 monorepo packages/components/src）
COMPONENTS_DIR=
# slidev 可执行命令（镜像内预装时覆盖，如 /usr/local/bin/slidev）；默认 npx slidev
SLIDEV_BIN=

# 对象存储 / CDN（按国内选型填写；S3 兼容：阿里云 OSS / 腾讯云 COS / RustFS 自建）
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=us-east-1
# RustFS 自建置 true，OSS/COS 置 false
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
CDN_BASE_URL=
# 无 OSS 时的本地产物回退目录（开发联调用）
LOCAL_STORAGE_ROOT=
