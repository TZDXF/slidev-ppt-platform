{
  "name": "slidev-ppt-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9.6.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @slidev-ppt/web dev",
    "dev:render": "pnpm --filter @slidev-ppt/render-service dev",
    "dev:build-worker": "pnpm --filter @slidev-ppt/build-worker dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
